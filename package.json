{
  "name": "movie-ticketing-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c magenta,cyan \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "seed:admin": "npm run seed:admin -w backend",
    "seed:catalog": "npm run seed:catalog -w backend",
    "verify:auth": "npm run verify:auth -w backend",
    "verify:phase2": "npm run verify:phase2 -w backend",
    "verify:phase3": "npm run verify:phase3 -w backend",
    "verify:phase4": "npm run verify:phase4 -w backend",
    "verify:phase5": "npm run verify:phase5 -w backend",
    "services:up": "docker compose --profile local-db --profile local-redis up -d --wait",
    "services:db:up": "docker compose --profile local-db up -d --wait",
    "services:redis:up": "docker compose --profile local-redis up -d --wait",
    "services:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}

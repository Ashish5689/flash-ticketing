{
  "name": "@book-my-show/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint src tests --max-warnings=0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "seed:catalog": "tsx src/scripts/seed-catalog.ts",
    "seed:showcase": "tsx src/scripts/seed-showcase.ts",
    "verify:auth": "tsx src/scripts/verify-auth-flow.ts",
    "verify:phase2": "tsx src/scripts/verify-phase-2.ts",
    "verify:phase3": "tsx src/scripts/verify-phase-3.ts",
    "verify:phase4": "tsx src/scripts/verify-phase-4.ts",
    "verify:phase5": "tsx src/scripts/verify-phase-5.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "ipaddr.js": "^1.9.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.35.3",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
